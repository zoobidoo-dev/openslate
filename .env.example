# ── Required ──────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string

# ── Domain (optional — set for custom domain + HTTPS) ─────
# DNS A record must point to your server's IP
DOMAIN=

# ── Cloudflare R2 (optional — media uploads) ─────────────
# Media uploads work only when all four are set.
# Leave empty to disable uploads (notes still work fine).
R2_BUCKET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
